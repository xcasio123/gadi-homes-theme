{%- liquid
  assign tabs = section.settings.tabs | split: ','
-%}

<div class="section faq-section">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="faq" data-faq>
      {%- if tabs.size > 1 -%}
        <div class="faq__tabs" role="tablist">
          {%- for tab in tabs -%}
            {%- assign tab_name = tab | strip -%}
            <button
              type="button"
              class="faq__tab"
              role="tab"
              data-faq-tab="{{ forloop.index }}"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
              {{ tab_name }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- for tab in tabs -%}
        <div class="faq__panel{% if forloop.first %} is-active{% endif %}" role="tabpanel" data-faq-panel="{{ forloop.index }}">
          {%- assign tab_index = forloop.index -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.tab == tab_index or tabs.size == 1 -%}
              <details class="faq-item" {{ block.shopify_attributes }}>
                <summary class="faq-item__q">
                  {{ block.settings.question }}
                  <span class="faq-item__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M12 5v14M5 12h14"/></svg>
                  </span>
                </summary>
                <div class="faq-item__a rte">{{ block.settings.answer }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    {
      "type": "text",
      "id": "tabs",
      "label": "Tabs (comma-separated)",
      "info": "e.g. General, Orders and Delivery, Returns",
      "default": "General, Orders & Delivery, Returns"
    }
  ],
  "blocks": [
    {
      "type": "qa",
      "name": "Question",
      "settings": [
        {
          "type": "range",
          "id": "tab",
          "label": "Tab number",
          "min": 1,
          "max": 6,
          "step": 1,
          "default": 1
        },
        { "type": "text", "id": "question", "label": "Question", "default": "Your question here" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Your answer here.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        { "type": "qa", "settings": { "tab": 1 } },
        { "type": "qa", "settings": { "tab": 1 } },
        { "type": "qa", "settings": { "tab": 2 } },
        { "type": "qa", "settings": { "tab": 3 } }
      ]
    }
  ]
}
{% endschema %}
