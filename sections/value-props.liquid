{%- liquid
  assign style_class = ''
  if section.settings.boxed
    assign style_class = ' value-props--bar'
  endif
-%}

<div class="section section--tight">
  <div class="page-width">
    <div class="value-props{{ style_class }}">
      {%- for block in section.blocks -%}
        <div class="value-prop" {{ block.shopify_attributes }}>
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'chat' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z"/></svg>
            {%- when 'return' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 7v6h6"/><path d="M3.5 13a9 9 0 1 0 2.1-9.4L3 7"/></svg>
            {%- when 'wallet' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H3z"/><path d="M16 11h3v4h-3a2 2 0 0 1 0-4z"/></svg>
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2 4 5v6c0 5 3.5 8.5 8 11 4.5-2.5 8-6 8-11V5z"/><path d="m9 12 2 2 4-4"/></svg>
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="9"/><path d="m9 12 2 2 4-4"/></svg>
          {%- endcase -%}
          <div class="value-prop__title">{{ block.settings.title }}</div>
          {%- if block.settings.text != blank -%}
            <div class="value-prop__text">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Value props",
  "settings": [
    { "type": "checkbox", "id": "boxed", "label": "Boxed background", "default": false }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Delivery" },
            { "value": "chat", "label": "Support" },
            { "value": "return", "label": "Returns" },
            { "value": "wallet", "label": "Payment" },
            { "value": "shield", "label": "Guarantee" },
            { "value": "check", "label": "Check" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature" },
        { "type": "text", "id": "text", "label": "Text" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Value props",
      "blocks": [
        { "type": "item", "settings": { "icon": "truck", "title": "Nationwide Delivery" } },
        { "type": "item", "settings": { "icon": "chat", "title": "Responsive Support" } },
        { "type": "item", "settings": { "icon": "return", "title": "7-Day Easy Returns" } },
        { "type": "item", "settings": { "icon": "wallet", "title": "COD & Bank Transfer" } }
      ]
    }
  ]
}
{% endschema %}
