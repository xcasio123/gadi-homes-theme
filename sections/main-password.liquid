<main class="section page-width" style="max-width:460px;text-align:center;padding-block:80px">
  {%- if shop.password_message != blank -%}
    <div class="rte" style="margin-bottom:20px">{{ shop.password_message }}</div>
  {%- endif -%}
  <h1>{{ shop.name }}</h1>
  <p style="color:var(--color-text-muted);margin-bottom:24px">Opening soon</p>
  {%- form 'storefront_password' -%}
    {%- if form.errors -%}
      <p style="color:var(--color-sale)">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
    {%- endif -%}
    <div style="display:flex;gap:10px;justify-content:center">
      <input type="password" name="password" placeholder="Enter password" aria-label="Password" style="padding:12px 14px;border:1px solid var(--color-border);border-radius:var(--card-corner)">
      <button type="submit" class="button">Enter</button>
    </div>
  {%- endform -%}
</main>
{% schema %}
{ "name": "Password", "settings": [] }
{% endschema %}
