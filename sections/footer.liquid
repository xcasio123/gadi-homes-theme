<div class="footer">
  <div class="page-width">
    <div class="footer__top">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'brand' -%}
            <div class="footer__brand" {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <div class="footer__logo">
                  <img src="{{ block.settings.logo | image_url: width: 400 }}" alt="{{ shop.name | escape }}" width="200" loading="lazy">
                </div>
              {%- else -%}
                <div class="header__logo-text">{{ shop.name }}</div>
              {%- endif -%}
              {%- if block.settings.tagline != blank -%}
                <p class="footer__tagline">{{ block.settings.tagline }}</p>
              {%- endif -%}
              <div class="footer__social">
                {%- if settings.social_facebook != blank -%}
                  <a href="{{ settings.social_facebook }}" aria-label="{{ 'general.social.facebook' | t }}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-2 0-3 1-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9z"/></svg></a>
                {%- endif -%}
                {%- if settings.social_instagram != blank -%}
                  <a href="{{ settings.social_instagram }}" aria-label="{{ 'general.social.instagram' | t }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
                {%- endif -%}
                {%- if settings.social_youtube != blank -%}
                  <a href="{{ settings.social_youtube }}" aria-label="{{ 'general.social.youtube' | t }}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12s0-3-.4-4.4a2.6 2.6 0 0 0-1.8-1.8C18.4 5.4 12 5.4 12 5.4s-6.4 0-7.8.4A2.6 2.6 0 0 0 2.4 7.6C2 9 2 12 2 12s0 3 .4 4.4a2.6 2.6 0 0 0 1.8 1.8c1.4.4 7.8.4 7.8.4s6.4 0 7.8-.4a2.6 2.6 0 0 0 1.8-1.8C22 15 22 12 22 12zm-12 3V9l5 3z"/></svg></a>
                {%- endif -%}
                {%- if settings.social_tiktok != blank -%}
                  <a href="{{ settings.social_tiktok }}" aria-label="{{ 'general.social.tiktok' | t }}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 4c.3 2 1.7 3.5 3.7 3.8v2.7c-1.4 0-2.7-.4-3.7-1.1v5.4a5.3 5.3 0 1 1-5.3-5.3c.3 0 .5 0 .8.1v2.8a2.6 2.6 0 1 0 1.8 2.5V4H16z"/></svg></a>
                {%- endif -%}
                {%- if settings.social_whatsapp != blank -%}
                  <a href="https://wa.me/{{ settings.social_whatsapp | remove: '+' | remove: ' ' }}" aria-label="{{ 'general.social.whatsapp' | t }}"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.4A10 10 0 1 0 12 2zm0 18a8 8 0 0 1-4.1-1.1l-.3-.2-2.9.8.8-2.8-.2-.3A8 8 0 1 1 12 20zm4.4-5.6c-.2-.1-1.4-.7-1.6-.8s-.4-.1-.5.1-.6.8-.8.9-.3.2-.5 0a6.5 6.5 0 0 1-1.9-1.2 7.2 7.2 0 0 1-1.3-1.7c-.1-.2 0-.4.1-.5l.4-.4.2-.4v-.4c0-.1-.5-1.3-.7-1.8s-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3A2.8 2.8 0 0 0 5 9.3c0 1.2.9 2.4 1 2.6s1.7 2.7 4.2 3.8a14 14 0 0 0 1.4.5c.6.2 1.1.2 1.5.1.5-.1 1.4-.6 1.6-1.1s.2-1 .1-1.1-.2-.2-.4-.3z"/></svg></a>
                {%- endif -%}
              </div>
            </div>

          {%- when 'menu' -%}
            <div class="footer__col" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <p class="footer__col-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- assign fmenu = block.settings.menu -%}
              {%- for link in fmenu.links -%}
                <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
              {%- endfor -%}
            </div>

          {%- when 'newsletter' -%}
            <div class="footer__col footer__newsletter" {{ block.shopify_attributes }}>
              {%- if block.settings.title != blank -%}
                <p class="footer__col-title">{{ block.settings.title }}</p>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <p class="footer__tagline" style="margin-bottom:14px">{{ block.settings.text }}</p>
              {%- endif -%}
              {%- form 'customer', class: 'footer__newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" aria-label="{{ 'general.newsletter.label' | t }}" required>
                <button type="submit" class="button button--full">{{ 'general.newsletter.button' | t }}</button>
                {%- if form.posted_successfully? -%}
                  <p style="margin-top:10px;font-size:.82rem">{{ 'general.newsletter.success' | t }}</p>
                {%- endif -%}
              {%- endform -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "copyright_text", "label": "Copyright text", "default": "All rights reserved." }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 1,
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Smart solutions that make every corner of your home easier and cleaner." }
      ]
    },
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Quick links" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Newsletter" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Subscribe for updates and special offers." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "brand" },
        { "type": "menu" },
        { "type": "menu" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
