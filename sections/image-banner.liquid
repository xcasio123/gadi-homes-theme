{%- liquid
  assign content_class = ''
  if section.settings.text_color == 'light'
    assign content_class = ' hero__content--light'
  endif
  if section.settings.position == 'right'
    assign content_class = content_class | append: ' hero__content--right'
  endif
-%}

<div class="hero hero--full">
  <a class="hero__media" {% if section.settings.link != blank %}href="{{ section.settings.link }}"{% endif %}>
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1920 }}"
        srcset="{{ section.settings.image | image_url: width: 750 }} 750w, {{ section.settings.image | image_url: width: 1100 }} 1100w, {{ section.settings.image | image_url: width: 1920 }} 1920w"
        sizes="100vw"
        alt="{{ section.settings.image.alt | escape | default: section.settings.heading | escape }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        fetchpriority="high">
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
    {%- endif -%}
  </a>

  {%- if section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank -%}
    <div class="hero__content{{ content_class }} page-width">
      {%- if section.settings.heading != blank -%}
        <h2 class="hero__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="hero__text">{{ section.settings.text }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.link | default: '#' }}" class="button">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    {
      "type": "select",
      "id": "position",
      "label": "Content position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    }
  ],
  "presets": [{ "name": "Image banner" }]
}
{% endschema %}
