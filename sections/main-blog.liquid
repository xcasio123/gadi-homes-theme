<div class="section">
  <div class="page-width">
    <div class="collection-header">
      <h1 class="collection-header__title">{{ blog.title }}</h1>
    </div>

    {%- paginate blog.articles by 12 -%}
      <div class="product-grid">
        {%- for article in blog.articles -%}
          <article class="product-card">
            <a href="{{ article.url }}" class="product-card__media">
              {%- if article.image -%}
                <img src="{{ article.image | image_url: width: 533 }}" alt="{{ article.image.alt | escape | default: article.title | escape }}" loading="lazy" width="400" height="400">
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'product-card__image' }}
              {%- endif -%}
            </a>
            <div class="product-card__info">
              <div class="product-card__vendor">{{ article.published_at | date: '%b %d, %Y' }}</div>
              <h3 class="product-card__title"><a href="{{ article.url }}">{{ article.title }}</a></h3>
              {%- if article.excerpt_or_content != blank -%}
                <p class="value-prop__text">{{ article.excerpt_or_content | strip_html | truncatewords: 18 }}</p>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination" aria-label="Pagination">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}<a href="{{ part.url }}">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}<span aria-current="page">{{ part.title }}</span>
            {%- else -%}<span>{{ part.title }}</span>{%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{ "name": "Blog posts", "settings": [] }
{% endschema %}
