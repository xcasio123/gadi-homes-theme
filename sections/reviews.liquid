{%- liquid
  assign full_stars = section.settings.rating | floor
-%}

<div class="section reviews">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading">
        <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    {%- if section.settings.show_summary -%}
      <div class="reviews__summary">
        <div class="reviews__stars" aria-hidden="true">
          {%- for i in (1..5) -%}{% if i <= full_stars %}&#9733;{% else %}&#9734;{% endif %}{%- endfor -%}
        </div>
        <p>
          <span class="reviews__rating">{{ section.settings.rating }}/5</span>
          {%- if section.settings.review_count != blank %} &middot; {{ section.settings.review_count }}{% endif -%}
        </p>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="reviews-grid">
        {%- for block in section.blocks -%}
          <div class="review-card" {{ block.shopify_attributes }}>
            <div class="review-card__stars" aria-hidden="true">
              {%- assign s = block.settings.stars | default: 5 -%}
              {%- for i in (1..5) -%}{% if i <= s %}&#9733;{% else %}&#9734;{% endif %}{%- endfor -%}
            </div>
            {%- if block.settings.text != blank -%}
              <p class="review-card__text">{{ block.settings.text }}</p>
            {%- endif -%}
            <div class="review-card__author">{{ block.settings.author }}</div>
            {%- if block.settings.verified -%}
              <div class="review-card__verified">Verified buyer</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Reviews",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "What our customers say" },
    { "type": "checkbox", "id": "show_summary", "label": "Show rating summary", "default": true },
    { "type": "text", "id": "rating", "label": "Average rating", "default": "4.7" },
    { "type": "text", "id": "review_count", "label": "Review count text", "default": "Verified reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        { "type": "textarea", "id": "text", "label": "Review text", "default": "Great quality and fast delivery." },
        { "type": "text", "id": "author", "label": "Author", "default": "Customer name" },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
