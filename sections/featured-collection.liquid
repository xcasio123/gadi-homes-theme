{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.product_limit
  assign layout_class = 'product-grid'
  if section.settings.layout == 'scroll'
    assign layout_class = 'product-scroller'
  endif
-%}

<div class="section featured-collection">
  <div class="page-width">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="section-heading">
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="section-heading__subtitle">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="{{ layout_class }}">
      {%- if collection and collection.products.size > 0 -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..limit) -%}
          {%- assign ph_index = i | modulo: 6 | plus: 1 -%}
          <div class="product-card">
            <div class="product-card__media">
              {{ 'product-' | append: ph_index | placeholder_svg_tag: 'product-card__image' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Example product</h3>
              <div class="price"><span class="price__regular">Rs.0.00</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and collection -%}
      <div class="collection-row__footer">
        <a href="{{ collection.url }}" class="button button--secondary">
          {{ section.settings.view_all_label | default: 'Load More' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection row",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured products" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "scroll", "label": "Horizontal scroll" }
      ],
      "default": "grid"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Show view-all button", "default": true },
    { "type": "text", "id": "view_all_label", "label": "View-all label", "default": "Load More" }
  ],
  "presets": [{ "name": "Collection row" }]
}
{% endschema %}
