{%- if section.blocks.size > 0 -%}
  <div class="announcement" role="region" aria-label="Announcements">
    {%- for block in section.blocks -%}
      <div class="announcement__inner" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
        {%- else -%}
          <span>{{ block.settings.text }}</span>
        {%- endif -%}
      </div>
      {%- break -%}
    {%- endfor -%}
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free shipping on orders over Rs. 2500"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Announcement bar",
      "blocks": [{ "type": "message" }]
    }
  ]
}
{% endschema %}
