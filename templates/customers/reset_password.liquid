<div class="section">
  <div class="page-width" style="max-width:420px">
    <div class="collection-header"><h1 class="collection-header__title">Reset password</h1></div>
    {%- form 'reset_customer_password' -%}
      {{ form.errors | default_errors }}
      <input type="password" name="customer[password]" placeholder="New password" style="width:100%;padding:12px 14px;border:1px solid var(--color-border);border-radius:var(--card-corner);margin-bottom:10px">
      <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" style="width:100%;padding:12px 14px;border:1px solid var(--color-border);border-radius:var(--card-corner);margin-bottom:10px">
      <button type="submit" class="button button--full">Reset password</button>
    {%- endform -%}
  </div>
</div>
