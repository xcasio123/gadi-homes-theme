<div class="section">
  <div class="page-width" style="max-width:820px">
    <div class="collection-header"><h1 class="collection-header__title">Order {{ order.name }}</h1></div>
    <p style="text-align:center;color:var(--color-text-muted)">Placed on {{ order.created_at | date: '%B %d, %Y' }}</p>

    <table style="width:100%;border-collapse:collapse;font-size:.88rem;margin-top:20px">
      <thead><tr style="text-align:left;border-bottom:1px solid var(--color-border)"><th style="padding:10px 8px">Product</th><th style="padding:10px 8px">Qty</th><th style="padding:10px 8px">Total</th></tr></thead>
      <tbody>
        {%- for line in order.line_items -%}
          <tr style="border-bottom:1px solid var(--color-border)">
            <td style="padding:10px 8px">{{ line.title }}</td>
            <td style="padding:10px 8px">{{ line.quantity }}</td>
            <td style="padding:10px 8px">{{ line.final_line_price | money }}</td>
          </tr>
        {%- endfor -%}
      </tbody>
      <tfoot>
        <tr><td colspan="2" style="padding:10px 8px;text-align:right">Subtotal</td><td style="padding:10px 8px">{{ order.subtotal_price | money }}</td></tr>
        <tr><td colspan="2" style="padding:10px 8px;text-align:right">Shipping</td><td style="padding:10px 8px">{{ order.shipping_price | money }}</td></tr>
        <tr style="font-weight:700"><td colspan="2" style="padding:10px 8px;text-align:right">Total</td><td style="padding:10px 8px">{{ order.total_price | money }}</td></tr>
      </tfoot>
    </table>
    <p style="margin-top:20px"><a href="{{ routes.account_url }}" class="link-underline">Back to account</a></p>
  </div>
</div>
