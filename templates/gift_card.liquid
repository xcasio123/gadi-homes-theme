<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ 'gift_cards.issued.title' | t: shop: shop.name }}</title>
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="template-gift-card">
  <main class="section page-width" style="max-width:480px;text-align:center">
    <h1 style="margin-top:30px">{{ shop.name }}</h1>
    <p style="color:var(--color-text-muted)">Gift card</p>
    <div style="background:var(--color-surface);border-radius:12px;padding:30px;margin:20px 0">
      <div style="font-size:2rem;font-weight:700">{{ gift_card.balance | money }}</div>
      {%- if gift_card.qr_identifier -%}
        <img src="{{ gift_card.qr_identifier | generate_qr_code }}" alt="QR code" style="margin:18px auto" width="160" height="160">
      {%- endif -%}
      <div style="font-family:monospace;letter-spacing:2px;font-size:1rem;word-break:break-all">{{ gift_card.code | format_code }}</div>
    </div>
    <a href="{{ shop.url }}" class="button">{{ 'gift_cards.issued.shop_link' | t }}</a>
  </main>
</body>
</html>
